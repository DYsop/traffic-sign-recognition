# -------------------------------------------------------------------
# ML artefacts — NEVER commit raw data, trained weights or run logs.
# Results that should be shown belong in reports/.
# -------------------------------------------------------------------
data/raw/**
data/interim/**
data/processed/**
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep
!data/README.md

checkpoints/**
!checkpoints/.gitkeep

# Runtime artefacts
runs/
logs/
wandb/
mlruns/
lightning_logs/
*.log

# Large binaries that should not be in git
*.pth
*.pt
*.ckpt
*.keras
*.h5
*.hdf5
*.onnx
*.tflite

# Allow curated assets under reports/figures/
!reports/figures/**

# -------------------------------------------------------------------
# Secrets
# -------------------------------------------------------------------
.env
.env.*
!.env.example
